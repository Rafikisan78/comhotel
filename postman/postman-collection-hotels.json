                  "pm.test(\"Hotel created with all fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.name).to.eql('Hôtel Plaza Paris');",
                  "    pm.expect(jsonData.stars).to.eql(4);",
                  "    pm.expect(jsonData.slug).to.exist;",
                  "    pm.expect(jsonData.is_active).to.be.true;",
                  "    pm.collectionVariables.set(\"hotel_id\", jsonData.id);",
                  "});",
                  "",
                  "pm.test(\"Slug is SEO-friendly\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.slug).to.match(/^[a-z0-9-]+$/);",
