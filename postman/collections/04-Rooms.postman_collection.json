        {
          "name": "Get Rooms by Hotel ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"All rooms belong to specified hotel\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    const hotelId = pm.collectionVariables.get('hotel_id');",
                  "    jsonData.forEach(room => {",
                  "        pm.expect(room.hotel_id).to.equal(hotelId);",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Rooms are sorted by room_number\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 1) {",
                  "        const roomNumbers = jsonData.map(r => r.room_number);",
                  "        const sortedNumbers = [...roomNumbers].sort();",
                  "        pm.expect(JSON.stringify(roomNumbers)).to.equal(JSON.stringify(sortedNumbers));",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
