    {
      "name": "Rooms CRUD",
      "item": [
        {
          "name": "Create Room - DOUBLE with Sea View",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has room data\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('room_number');",
                  "    pm.expect(jsonData).to.have.property('room_type');",
                  "    pm.expect(jsonData).to.have.property('base_price');",
                  "    ",
                  "    // Save room_id for next requests",
                  "    pm.collectionVariables.set('room_id', jsonData.id);",
                  "});",
                  "",
                  "pm.test(\"Room type is DOUBLE\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.room_type).to.equal('double');",
                  "});",
                  "",
                  "pm.test(\"View type is SEA\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.view_type).to.equal('sea');",
                  "});",
                  "",
                  "pm.test(\"Room is active by default\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.is_active).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Has created_at and updated_at timestamps\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('created_at');",
                  "    pm.expect(jsonData).to.have.property('updated_at');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hotel_id\": \"{{hotel_id}}\",\n  \"room_number\": \"101\",\n  \"room_type\": \"double\",\n  \"floor\": 1,\n  \"capacity_adults\": 2,\n  \"capacity_children\": 1,\n  \"capacity_infants\": 0,\n  \"base_price\": 150.00,\n  \"size_sqm\": 25,\n  \"view_type\": \"sea\",\n  \"description\": \"Belle chambre double avec vue sur mer\",\n  \"is_accessible\": false,\n  \"is_smoking_allowed\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/rooms",
              "host": ["{{base_url}}"],
              "path": ["rooms"]
            }
          }
        },
