        {
          "name": "Get All Rooms",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"All rooms are active by default\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    jsonData.forEach(room => {",
                  "        pm.expect(room.is_active).to.be.true;",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Rooms are sorted by created_at desc\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 1) {",
                  "        const firstDate = new Date(jsonData[0].created_at);",
                  "        const secondDate = new Date(jsonData[1].created_at);",
                  "        pm.expect(firstDate >= secondDate).to.be.true;",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
              }
