        {
          "name": "Soft Delete Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Room was soft deleted\", function () {",
                  "    // Verify by trying to get the room again",
                  "    const roomId = pm.collectionVariables.get('room_id');",
                  "    ",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('base_url') + '/rooms/' + roomId,",
                  "        method: 'GET',",
                  "        header: {",
                  "            'Authorization': 'Bearer ' + pm.collectionVariables.get('owner_token')",
                  "        }",
                  "    }, function (err, response) {",
                  "        if (!err) {",
                  "            const room = response.json();",
                  "            // Room should still exist but is_active should be false",
                  "            pm.expect(room.is_active).to.be.false;",
                  "        }",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{owner_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/rooms/{{room_id}}",
              "host": ["{{base_url}}"],
              "path": ["rooms", "{{room_id}}"]
            }
          }
        }
      ]
